# Public site URL — used to build canonical URLs, sitemap.xml, robots.txt.
SITE_URL=https://rickarko.com

# Flask runtime mode: "development" enables debug; anything else is production.
FLASK_ENV=development

# Port the local dev server binds to.
PORT=8080

# Optional path overrides — leave unset unless relocating data/templates/static.
# APP_DATA_DIR=
# APP_TEMPLATE_DIR=
# APP_STATIC_DIR=

# Flask session signing key. Generate a long random string for any environment
# you actually want to gate. Production values must be set via App Runner env,
# not committed here. Example: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=

# Credentials that gate /blog/ (Insights). Empty values disable sign-in entirely.
# Production values must be set via App Runner env, not committed here.
INSIGHTS_USERNAME=
INSIGHTS_PASSWORD=

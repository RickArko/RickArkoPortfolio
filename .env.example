# Public site URL — used to build canonical URLs, sitemap.xml, robots.txt.
SITE_URL=https://rickarko.com

# Flask runtime mode: "development" enables debug; anything else is production.
FLASK_ENV=development

# Port the local dev server binds to.
PORT=8080

# Optional path overrides — leave unset unless relocating data/templates/static.
# APP_DATA_DIR=
# APP_TEMPLATE_DIR=
# APP_STATIC_DIR=

# Flask session signing key. MUST be a long random string in production.
SECRET_KEY=rickarko-portfolio-dev-secret-replace-in-production

# Credentials that gate /blog/ (Insights). Override in production via env.
INSIGHTS_USERNAME=rickarko
INSIGHTS_PASSWORD=IamRickarko
